const PFX=['Zor','Vib','Kry','Zab','Nex','Blix','Grix','Fob','Triz','Wex','Qox','Zeph','Brak','Slix','Yorb','Zav','Plok','Skib'];
const MID=['al','ox','ib','eb','ar','ix','ob','ax','it','uz','ek','or','ab','el','in','im','av','ik'];
const SFX=['ax','on','ix','ob','ar','ex','ib','oz','ur','ak','en','ov','um','yx','az','ib','ek','or'];
function genZName(n){
  if(!n)return'';let s=0;
  for(let i=0;i<n.length;i++)s=(s*31+n.charCodeAt(i))&0xffffffff;
  const r=(x)=>{s=(s*1664525+1013904223)&0xffffffff;return Math.abs(s)%x;};
  return PFX[r(PFX.length)]+MID[r(MID.length)]+SFX[r(SFX.length)];
}
function liveGen(){
  const n=document.getElementById('gen-input').value.trim();
  if(!n){document.getElementById('genRC').style.display='none';return;}
