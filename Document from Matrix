    document.getElementById('inputLbl').textContent='ENTER '+shortLang+' TEXT';
    document.getElementById('outputLbl').textContent='ENGLISH OUTPUT';
    document.getElementById('dirBar').innerHTML='Translating <span>'+lang+' → English</span>';
  }
  out.textContent='Translation will appear here...';out.className='tout ph';
  document.getElementById('transInput').value='';
  const pw=document.getElementById('pronWrap');
  if(pw) pw.style.display='none';
}

function doTranslate(){
  const text=document.getElementById('transInput').value.trim();
  const out=document.getElementById('transOutput');
  if(!text){out.textContent='Please enter text first.';out.className='tout ph';return;}
  const words=text.toLowerCase().split(/\s+/);
  let result=[];
  if(tDir==='e2z'){
    for(const w of words){
      const c=w.replace(/[^a-z0-9]/g,'');
      if(e2z[c]){result.push(e2z[c]);}
      else if(/^\d+$/.test(c)){const n=parseInt(c);result.push(n>=0&&n<=100?NN[n]:c);}
      else{let f=false;for(const[k,v] of Object.entries(e2z)){if(c.length>2&&k.includes(c)){result.push(v);f=true;break;}}if(!f)result.push('Zob-'+c);}
    }
  } else {
    let i=0;
    while(i<words.length){
      let m=false;
      if(i+2<words.length){const t3=words[i]+' '+words[i+1]+' '+words[i+2];if(z2e[t3]){result.push(z2e[t3]);i+=3;m=true;}}
      if(!m&&i+1<words.length){const t2=words[i]+' '+words[i+1];if(z2e[t2]){result.push(z2e[t2]);i+=2;m=true;}}
      if(!m){const ww=words[i].replace(/[^a-z]/g,'');result.push(z2e[ww]||('['+words[i]+'?]'));i++;}
    }
  }
  const finalText = result.join(' ');
  out.textContent=finalText;out.className='tout';
  // Show pronounce button
  document.getElementById('pronWrap').style.display='block';
  document.getElementById('pronStatus').textContent='';
  const lang4btn = currentPlanet && currentPlanet.dict ? currentPlanet.lang : 'Zorblax';
  const pbtn = document.getElementById('pronounceBtn');
  if(pbtn) pbtn.textContent = '🔊 PRONOUNCE IN ' + lang4btn.toUpperCase();
  // Show phonetic breakdown
  const ph = document.getElementById('phonetic');
  if(tDir==='e2z' && finalText && !finalText.startsWith('Translation')){
    ph.textContent = makePhonetic(finalText);
    ph.style.display='block';
  } else {
    ph.style.display='none';
  }
}
document.addEventListener('keydown',e=>{if(e.key==='Enter'&&e.ctrlKey)doTranslate();});

