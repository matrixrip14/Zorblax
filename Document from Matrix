let currentPlanet=TRAVEL_PLANETS[0];
let travelTarget=null;

function renderTravelPlanets(){
  const list=document.getElementById('travelPlanetList');
  if(!list) return;
  list.innerHTML=TRAVEL_PLANETS.filter(p=>p.id!==currentPlanet.id).map(p=>{
    const hasNat=checkHasNat(p.id);
    const freeEntry=hasNat||!p.needsNat;
    const waitText=freeEntry?'✅ Free entry':'⏳ '+p.travelMin+'–'+p.travelMax+' min travel';
    return `<div class="tplanet-card" data-pid="${p.id}" onclick="selectTravelDest(this.dataset.pid)">
      <div class="tplanet-banner" style="background:${p.bgColor}">
        <span class="tplanet-icon">${p.icon}</span>
        <div style="position:absolute;bottom:8px;left:12px;font-family:'Orbitron',sans-serif;font-size:9px;color:rgba(255,255,255,.6);letter-spacing:1px">${p.lang}</div>
      </div>
      <div class="tplanet-info">
        <h3>${p.name}</h3>
        <div class="tplanet-meta"><span>📡 ${p.distance} AU</span><span>⏱ ${p.travelMin}–${p.travelMax} min</span></div>
        <div style="font-size:10px;color:var(--muted);margin-bottom:8px;line-height:1.5">${p.desc}</div>
        <div class="tplanet-tags">
          <span class="ttag ${freeEntry?'free':'visa'}">${waitText}</span>
          <span class="ttag ${p.danger}">${p.danger==='safe'?'✅ Safe':p.danger==='neutral'?'⚠️ Caution':'🔴 Danger'}</span>
        </div>
      </div>
    </div>`;
  }).join('');
  const locEl=document.getElementById('currentLocIcon');if(locEl)locEl.textContent=currentPlanet.icon;
  const nmEl=document.getElementById('currentLocName');if(nmEl)nmEl.textContent=currentPlanet.name;
  const lgEl=document.getElementById('currentLocLang');if(lgEl)lgEl.textContent='Language: '+currentPlanet.lang;
}

function checkHasNat(planetId){
  const reg=getReg();
  for(const[k,v] of Object.entries(reg)){
    if(k.startsWith('nat_')&&v.status==='approved'){
      const match=TRAVEL_PLANETS.find(p=>p.id===planetId&&p.name===v.planet);
      if(match)return true;
    }
  }
  return false;
}

function selectTravelDest(planetId){
  const planet=TRAVEL_PLANETS.find(p=>p.id===planetId);
  if(!planet)return;
  travelTarget=planet;
  const modal=document.getElementById('airlineModal');
  if(!modal)return;
  document.getElementById('airlineDestText').textContent='Travelling to '+planet.name;
  document.getElementById('airlineOptions').innerHTML=planet.airlines.map((a,i)=>{
    const times=['Standard','Express','Budget'];const icons=['🛸','✈️','🚀'];
    return `<div class="airline-option" data-pid="${planetId}" data-aidx="${i}" onclick="bookFlight(this.dataset.pid,parseInt(this.dataset.aidx))">
      <div class="airline-logo">${icons[i%3]}</div>
      <div class="airline-info"><h4>${a}</h4><p>${times[i%3]}</p></div>
      
    </div>`;
  }).join('');
  modal.style.display='flex';
}

function closeAirlineModal(e){
  if(!e||e.target===document.getElementById('airlineModal'))
    document.getElementById('airlineModal').style.display='none';
}

function bookFlight(planetId,airlineIdx){
  const planet=TRAVEL_PLANETS.find(p=>p.id===planetId);
  if(!planet)return;
  document.getElementById('airlineModal').style.display='none';
  // Real countdown timer based on actual travel minutes
  const planet2=TRAVEL_PLANETS.find(p=>p.id===planetId);
  const mins=planet2?planet2.travelMin:8;
  const realSecs=mins*60; // 1 real minute per galactic minute
  startTravel(planet,planet.airlines[airlineIdx%planet.airlines.length],planet.travelMin,planet.travelMax,realSecs);
}

function startTravel(planet,airline,minMins,maxMins,realSecs){
  const overlay=document.getElementById('travelOverlay');
  if(!overlay)return;
  overlay.style.display='flex';
  document.getElementById('travelBigIcon').textContent='🚀';
  document.getElementById('travelStatusText').textContent='PREPARING FOR LAUNCH';
  document.getElementById('travelSubText').textContent='Boarding '+airline+' — Destination: '+planet.name;
  document.getElementById('travelProgBar').style.width='0%';
  document.getElementById('travelETA').textContent='ETA: '+minMins+'–'+maxMins+' galactic minutes';
  // Animate stars
  const starsEl=document.getElementById('travelStarsAnim');
  starsEl.innerHTML='';
  for(let i=0;i<50;i++){
    const s=document.createElement('div');s.className='travel-star';
    const x=Math.random()*window.innerWidth,y=Math.random()*window.innerHeight;
    const dx=(Math.random()-.5)*800,dy=(Math.random()-.5)*800;
    const dur=.4+Math.random()*1.2;
    s.style.cssText=`left:${x}px;top:${y}px;--dx:${dx}px;--dy:${dy}px;animation-duration:${dur}s;animation-delay:${Math.random()*2}s;`;
    starsEl.appendChild(s);
  }
  const phases=[
    {pct:5,status:'LAUNCH SEQUENCE',sub:'Engines igniting...'},
    {pct:20,status:'LEAVING ORBIT',sub:'Breaking through atmosphere...'},
    {pct:40,status:'DEEP SPACE',sub:'Cruising at warp speed...'},
    {pct:65,status:'APPROACHING '+planet.name.toUpperCase(),sub:'Almost there...'},
    {pct:85,status:'ENTERING ORBIT',sub:'Preparing landing sequence...'},
    {pct:100,status:'ARRIVED!',sub:'Welcome to '+planet.name+'!'},
  ];
  const startTime=Date.now();const totalMs=realSecs*1000;let phaseIdx=0;
  const interval=setInterval(()=>{
    const elapsed=Date.now()-startTime;
    const pct=Math.min(100,(elapsed/totalMs)*100);
    document.getElementById('travelProgBar').style.width=pct+'%';
    const remaining=Math.max(0,Math.round((totalMs-elapsed)/1000));
    document.getElementById('travelETA').textContent=pct<100?'ETA: ~'+remaining+'s ('+Math.round(minMins+(maxMins-minMins)*(1-pct/100))+' galactic min)':'🎉 LANDED!';
    while(phaseIdx<phases.length&&pct>=phases[phaseIdx].pct){
      document.getElementById('travelStatusText').textContent=phases[phaseIdx].status;
      document.getElementById('travelSubText').textContent=phases[phaseIdx].sub;
      if(phases[phaseIdx].pct>=40)document.getElementById('travelBigIcon').textContent=planet.icon;
      phaseIdx++;
    }
    if(pct>=100){clearInterval(interval);setTimeout(()=>{overlay.style.display='none';arrivedOnPlanet(planet);},1200);}
  },200);
}

function arrivedOnPlanet(planet){
  currentPlanet=planet;
  applyPlanetTheme(planet);
  renderTravelPlanets();
  showNotice('🎉 Welcome to '+planet.name+'!');
  SP('home',document.querySelector('nav button'));
}

function applyPlanetTheme(planet){
  const banner=document.getElementById('planetBanner');
  if(!banner)return;
  if(planet.id==='zarb'){
    banner.style.display='none';
    resetToPlanet(null);
    return;
  }
  banner.style.display='flex';
  banner.style.borderColor=planet.color;
  document.getElementById('pbIcon').textContent=planet.icon;
  document.getElementById('pbName').textContent=planet.name.toUpperCase();
  document.getElementById('pbLang').textContent='Speaking: '+planet.lang;
  document.getElementById('pbHomeBtn').style.cssText='border-color:'+planet.color+';color:'+planet.color;
  resetToPlanet(planet);
}

function resetToPlanet(planet){
  // Update home title
  const title=document.querySelector('.ztitle');
  if(title)title.textContent=planet?planet.lang.toUpperCase():'ZORBLAX';
  // Update nav color
  document.querySelector('nav').style.borderBottomColor=planet?planet.color:'var(--border)';
  // Update dictionary
  updateDictForPlanet(planet);
}

function updateDictForPlanet(planet){
  if(!planet||!planet.dict){
    // Reset to Zorblax dictionary
    renderDicts();
    const dhdr=document.querySelector('.dhdr div:first-child');
    if(dhdr)dhdr.textContent='📚 DICTIONARY';
    updateWC();
    // Reset translator lookups to Zorblax
    e2z={}; z2e={};
    buildLookup();
    // Reset translator UI
    tDir='e2z';
    document.querySelectorAll('.ttab').forEach(b=>b.classList.remove('active'));
    const be=document.getElementById('btn-e2z');
    if(be){be.classList.add('active');be.textContent='🌍 ENG → ZORBLAX';}
    const bz=document.getElementById('btn-z2e');
    if(bz) bz.textContent='👽 ZORBLAX → ENG';
    const db=document.getElementById('dirBar');
    if(db) db.innerHTML='Translating <span>English → Zorblax</span>';
    const il=document.getElementById('inputLbl');
    if(il) il.textContent='ENTER ENGLISH TEXT';
    const ol=document.getElementById('outputLbl');
    if(ol) ol.textContent='ZORBLAX OUTPUT';
    const ti=document.getElementById('transInput');
    if(ti) ti.placeholder='Type English...';
    const to=document.getElementById('transOutput');
    if(to){to.textContent='Translation will appear here...';to.className='tout ph';}
    const pw=document.getElementById('pronWrap');
    if(pw) pw.style.display='none';
    return;
  }
  // Planet-specific dictionary
  const d=planet.dict;
  const dhdr=document.querySelector('.dhdr div:first-child');
  if(dhdr)dhdr.textContent='📚 '+planet.lang.toUpperCase();
  const cats=Object.keys(d);
  const content=document.getElementById('dictContent');
  if(content){
    content.innerHTML=cats.map((cat,i)=>`<div class="dc ${i===0?'active':''}" id="cat-${cat}"><h2>${cat.toUpperCase()}</h2><div class="wl">${d[cat].map(w=>`<div class="wi"><span class="wz" style="color:${planet.color}">${w[0]}</span><span class="we">${w[1]}</span></div>`).join('')}</div></div>`).join('');
  }
  const ctabs=document.querySelector('.ctabs');
  if(ctabs){
    ctabs.innerHTML=cats.map((cat,i)=>`<button class="cb${i===0?' active':''}" data-cat="${cat}" onclick="showCat(this.dataset.cat,this)">${cat.charAt(0).toUpperCase()+cat.slice(1)}</button>`).join('');
  }
  const total=cats.reduce((s,k)=>s+d[k].length,0);
  const wcEl=document.getElementById('totalWC');
  if(wcEl)wcEl.textContent=total+' ('+planet.lang+')';
  // Update translator lookups to planet language
  e2z={}; z2e={};
  for(const[cat,words] of Object.entries(d)){
    words.forEach(w=>{
      e2z[w[1].toLowerCase()]=w[0];
      z2e[w[0].toLowerCase()]=w[1];
    });
  }
  // Update translator UI for this planet
  const langName=planet.lang.toUpperCase();
  const shortName=planet.lang.length>8?planet.lang.split(' ')[0].toUpperCase():langName;
  tDir='e2z';
  document.querySelectorAll('.ttab').forEach(b=>b.classList.remove('active'));
  const be2=document.getElementById('btn-e2z');
  if(be2){be2.classList.add('active');be2.textContent='🌍 ENG → '+shortName;}
  const bz2=document.getElementById('btn-z2e');
  if(bz2) bz2.textContent='👽 '+shortName+' → ENG';
  const db2=document.getElementById('dirBar');
  if(db2) db2.innerHTML='Translating <span>English → '+langName+'</span>';
  const il2=document.getElementById('inputLbl');
  if(il2) il2.textContent='ENTER ENGLISH TEXT';
  const ol2=document.getElementById('outputLbl');
  if(ol2) ol2.textContent=langName+' OUTPUT';
  const ti2=document.getElementById('transInput');
  if(ti2) ti2.placeholder='Type English...';
  const to2=document.getElementById('transOutput');
  if(to2){to2.textContent='Translation will appear here...';to2.className='tout ph';}
  const pw2=document.getElementById('pronWrap');
  if(pw2) pw2.style.display='none';
}

function returnHome(){
  currentPlanet=TRAVEL_PLANETS[0];
  document.getElementById('planetBanner').style.display='none';
  document.querySelector('nav').style.borderBottomColor='var(--border)';
  resetToPlanet(null);
  renderTravelPlanets();
  SP('home',document.querySelector('nav button'));
  showNotice('🏠 Welcome back to Zarb (Mars)!');
}

