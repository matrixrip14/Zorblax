<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zorblax Language</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Exo+2:wght@300;400;600&display=swap');
:root{--bg:#050a1a;--card:#0d1f3c;--glow:#00e5ff;--glow2:#7c4dff;--accent:#39ff14;--text:#c8e6ff;--muted:#5a7fa8;--border:#1a3a5c;--red:#ff6b6b;--gold:#ffd700;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:"Exo 2",sans-serif;min-height:100vh;}
.stars{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;overflow:hidden;}
.star{position:absolute;background:white;border-radius:50%;animation:twinkle linear infinite;}
@keyframes twinkle{0%,100%{opacity:.1}50%{opacity:.8}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes glowtitle{from{filter:drop-shadow(0 0 8px rgba(0,229,255,.3))}to{filter:drop-shadow(0 0 25px rgba(124,77,255,.6))}}
nav{position:sticky;top:0;z-index:200;background:rgba(5,10,26,.98);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;padding:0 2px;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;}
nav::-webkit-scrollbar{display:none;}
nav button{background:none;border:none;padding:12px 10px;font-family:"Orbitron",sans-serif;font-size:8px;font-weight:700;color:var(--muted);cursor:pointer;letter-spacing:.5px;border-bottom:2px solid transparent;transition:all .3s;white-space:nowrap;flex-shrink:0;}
nav button.active{color:var(--glow);border-bottom-color:var(--glow);text-shadow:0 0 10px var(--glow);}
nav button:hover:not(.active){color:var(--text);}
.page{display:none;padding:14px 12px 80px;position:relative;z-index:1;}
.page.active{display:block;}
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px;position:relative;overflow:hidden;margin-bottom:12px;}
.card::before{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--glow),var(--glow2));}
.card h3{font-family:"Orbitron",sans-serif;font-size:10px;letter-spacing:2px;color:var(--glow);margin-bottom:10px;}
.btn{width:100%;background:linear-gradient(135deg,rgba(0,229,255,.12),rgba(124,77,255,.12));border:1px solid var(--glow);border-radius:8px;padding:11px;font-family:"Orbitron",sans-serif;font-size:9px;letter-spacing:1.5px;color:var(--glow);cursor:pointer;transition:all .3s;margin:7px 0;display:block;text-align:center;}
.btn:hover{background:linear-gradient(135deg,rgba(0,229,255,.22),rgba(124,77,255,.22));}
.btn.acc{border-color:var(--accent);color:var(--accent);}
.btn.gld{border-color:var(--gold);color:var(--gold);}
.fg{margin-bottom:10px;}
.fg label{font-family:"Orbitron",sans-serif;font-size:7px;letter-spacing:2px;color:var(--muted);display:block;margin-bottom:4px;}
.fg input,.fg select{width:100%;background:rgba(0,229,255,.04);border:1px solid var(--border);border-radius:7px;padding:9px 11px;font-family:"Exo 2",sans-serif;font-size:13px;color:var(--text);outline:none;transition:border-color .3s;}
.fg input:focus,.fg select:focus{border-color:var(--glow);}
.fg input::placeholder{color:var(--muted);}
.fg select option{background:var(--card);}
.hint{font-size:9px;color:var(--muted);margin-top:3px;}
.tag{display:inline-block;background:rgba(0,229,255,.1);border:1px solid rgba(0,229,255,.2);border-radius:10px;padding:2px 7px;font-size:9px;color:var(--glow);margin:2px;}
.tag.en{background:rgba(255,50,50,.1);border-color:rgba(255,50,50,.3);color:var(--red);}
.tag.al{background:rgba(57,255,20,.1);border-color:rgba(57,255,20,.3);color:var(--accent);}
.rb{display:inline-block;padding:2px 7px;border-radius:10px;font-size:8px;font-family:"Orbitron",sans-serif;font-weight:700;}
.r0{background:rgba(150,150,150,.15);color:#aaa;border:1px solid #555;}
.r1{background:rgba(0,229,255,.1);color:var(--glow);border:1px solid rgba(0,229,255,.3);}
.r2{background:rgba(57,255,20,.1);color:var(--accent);border:1px solid rgba(57,255,20,.3);}
.r3{background:rgba(255,200,0,.1);color:#ffc800;border:1px solid rgba(255,200,0,.3);}
.r4{background:rgba(255,100,0,.1);color:#ff8c00;border:1px solid rgba(255,100,0,.3);}
.r5{background:rgba(200,0,255,.15);color:#e040fb;border:1px solid rgba(200,0,255,.3);}
.r6{background:rgba(0,100,255,.15);color:#4db6ff;border:1px solid rgba(0,100,255,.3);}
.r7{background:rgba(255,50,50,.1);color:var(--red);border:1px solid rgba(255,50,50,.3);}
.r8{background:rgba(255,255,255,.08);color:#fff;border:1px solid rgba(255,255,255,.25);}
.r9{background:rgba(255,215,0,.15);color:var(--gold);border:1px solid rgba(255,215,0,.4);}
.ztitle{font-family:"Orbitron",sans-serif;font-size:clamp(32px,9vw,70px);font-weight:900;letter-spacing:5px;background:linear-gradient(135deg,#00e5ff 0%,#7c4dff 50%,#39ff14 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;margin-bottom:8px;animation:glowtitle 3s ease-in-out infinite alternate;}
.cbadge{display:inline-block;background:linear-gradient(135deg,rgba(0,229,255,.1),rgba(124,77,255,.1));border:1px solid rgba(0,229,255,.3);border-radius:50px;padding:7px 18px;font-size:11px;color:var(--glow);letter-spacing:2px;font-family:"Orbitron",sans-serif;margin-bottom:24px;}
.cbadge span{color:var(--accent);font-weight:700;}
.pr{display:flex;justify-content:space-between;align-items:center;padding:7px 10px;background:rgba(0,229,255,.04);border-radius:6px;border-left:2px solid var(--glow2);margin-bottom:5px;}
.pz{font-family:"Orbitron",sans-serif;font-size:11px;color:var(--glow);}
.pe{font-size:11px;color:var(--muted);}
.dhdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
.wcbadge{background:linear-gradient(135deg,rgba(0,229,255,.15),rgba(124,77,255,.15));border:1px solid var(--glow);border-radius:20px;padding:4px 12px;font-family:"Orbitron",sans-serif;font-size:9px;color:var(--glow);letter-spacing:1px;}
.dsearch{position:relative;margin-bottom:8px;}
.dsearch input{width:100%;background:var(--card);border:1px solid var(--border);border-radius:7px;padding:9px 34px 9px 12px;font-family:"Exo 2",sans-serif;font-size:12px;color:var(--text);outline:none;}
.dsearch input:focus{border-color:var(--glow);}
.dsearch input::placeholder{color:var(--muted);}
.si{position:absolute;right:11px;top:50%;transform:translateY(-50%);color:var(--muted);}
.ctabs{display:flex;gap:5px;overflow-x:auto;padding-bottom:3px;margin-bottom:8px;scrollbar-width:none;}
.ctabs::-webkit-scrollbar{display:none;}
.cb{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:4px 10px;font-family:"Exo 2",sans-serif;font-size:9px;font-weight:600;color:var(--muted);cursor:pointer;white-space:nowrap;transition:all .3s;}
.cb.active,.cb:hover{background:rgba(0,229,255,.1);border-color:var(--glow);color:var(--glow);}
.dc{display:none;}
.dc.active{display:block;}
.dc h2{font-family:"Orbitron",sans-serif;font-size:10px;letter-spacing:2px;color:var(--glow2);margin-bottom:8px;padding-bottom:5px;border-bottom:1px solid var(--border);}
.wl{display:flex;flex-direction:column;gap:4px;margin-bottom:14px;}
.wi{display:flex;justify-content:space-between;align-items:center;padding:7px 10px;background:var(--card);border:1px solid var(--border);border-radius:6px;}
.wi:hover{border-color:var(--glow);}
.wz{font-family:"Orbitron",sans-serif;font-size:9px;color:var(--glow);font-weight:700;}
.we{font-size:10px;color:var(--text);}
.wi.sp{border-color:var(--accent);}
.wi.sp .wz{color:var(--accent);}
.ngrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:4px;margin-bottom:14px;}
.ni{background:var(--card);border:1px solid var(--border);border-radius:6px;padding:6px 9px;display:flex;justify-content:space-between;align-items:center;}
.nv{font-family:"Orbitron",sans-serif;font-size:13px;color:var(--glow2);font-weight:700;}
.nz{font-size:8px;color:var(--muted);}
.tw{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:12px;}
.ttabs{display:flex;border-bottom:1px solid var(--border);}
.ttab{flex:1;background:none;border:none;padding:11px;font-family:"Orbitron",sans-serif;font-size:8px;letter-spacing:.8px;color:var(--muted);cursor:pointer;transition:all .3s;border-bottom:2px solid transparent;}
.ttab.active{color:var(--glow);background:rgba(0,229,255,.05);border-bottom-color:var(--glow);}
.tbody{padding:12px;}
.tlbl{font-family:"Orbitron",sans-serif;font-size:8px;letter-spacing:2px;color:var(--muted);margin-bottom:5px;}
textarea{width:100%;background:rgba(0,229,255,.03);border:1px solid var(--border);border-radius:6px;padding:9px;font-family:"Exo 2",sans-serif;font-size:12px;color:var(--text);resize:vertical;min-height:75px;outline:none;}
textarea:focus{border-color:var(--glow);}
textarea::placeholder{color:var(--muted);}
.tout{background:rgba(0,229,255,.04);border:1px solid var(--border);border-radius:6px;padding:9px;min-height:55px;font-family:"Orbitron",sans-serif;font-size:11px;color:var(--accent);letter-spacing:.8px;line-height:1.7;word-break:break-word;}
.tout.ph{color:var(--muted);font-family:"Exo 2",sans-serif;font-size:11px;letter-spacing:0;}
.dbar{text-align:center;font-size:9px;color:var(--muted);padding:7px;background:rgba(124,77,255,.05);border-top:1px solid var(--border);}
.dbar span{color:var(--glow2);font-weight:600;}
.ac{background:var(--card);border:1px solid var(--border);border-radius:11px;overflow:hidden;margin-bottom:10px;}
.ahdr{display:flex;align-items:center;gap:11px;padding:12px;cursor:pointer;}
.ainfo h3{font-family:"Orbitron",sans-serif;font-size:11px;color:var(--glow);margin-bottom:2px;}
.ainfo p{font-size:9px;color:var(--muted);}
.abody{display:none;padding:0 12px 12px;}
.abody.open{display:block;}
.astat{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:10px;}
.ak{color:var(--muted);}
.av{color:var(--text);text-align:right;max-width:60%;font-weight:600;}
.itabs{display:flex;gap:5px;margin-bottom:12px;}
.itab{flex:1;background:var(--card);border:1px solid var(--border);border-radius:6px;padding:8px;font-family:"Orbitron",sans-serif;font-size:8px;letter-spacing:1px;color:var(--muted);cursor:pointer;transition:all .3s;}
.itab.active{border-color:var(--glow);color:var(--glow);background:rgba(0,229,255,.08);}
.ipanel{display:none;}
.ipanel.active{display:block;}
.passport{background:linear-gradient(135deg,#0a2040,#0d1f3c,#0a1628);border:2px solid var(--glow2);border-radius:13px;padding:18px;max-width:340px;margin:0 auto 12px;position:relative;overflow:hidden;}
.passport::before{content:"ZORBLAX EMPIRE";position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-30deg);font-family:"Orbitron",sans-serif;font-size:38px;font-weight:900;color:rgba(124,77,255,.05);white-space:nowrap;pointer-events:none;}
.pphdr{text-align:center;margin-bottom:14px;border-bottom:1px solid rgba(124,77,255,.3);padding-bottom:11px;}
.pphdr .flag{font-size:26px;margin-bottom:3px;}
.pphdr h2{font-family:"Orbitron",sans-serif;font-size:10px;letter-spacing:3px;color:var(--glow2);}
.pphdr p{font-size:8px;color:var(--muted);letter-spacing:2px;margin-top:2px;}
.ppphoto{width:56px;height:68px;background:rgba(0,229,255,.05);border:2px solid var(--glow);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:28px;float:right;margin-left:10px;}
.ppf{margin-bottom:7px;}
.ppf label{font-family:"Orbitron",sans-serif;font-size:6px;letter-spacing:2px;color:var(--muted);display:block;margin-bottom:2px;}
.ppf .v{font-family:"Orbitron",sans-serif;font-size:11px;color:var(--text);font-weight:700;min-height:16px;}
.ppf .v.mono{letter-spacing:2px;color:var(--glow);font-size:10px;}
.ppmrz{background:rgba(0,0,0,.3);border-radius:5px;padding:7px;margin-top:12px;font-family:"Orbitron",sans-serif;font-size:8px;color:var(--muted);letter-spacing:1.5px;word-break:break-all;}
.icard{background:linear-gradient(135deg,#0d1f3c,#050a1a);border:2px solid var(--glow);border-radius:9px;padding:14px;max-width:340px;margin:0 auto 12px;position:relative;overflow:hidden;}
.ichdr{display:flex;align-items:center;gap:7px;margin-bottom:10px;padding-bottom:7px;border-bottom:1px solid rgba(0,229,255,.2);}
.ichdr h2{font-family:"Orbitron",sans-serif;font-size:9px;letter-spacing:1.5px;color:var(--glow);}
.icphoto{width:46px;height:55px;background:rgba(0,229,255,.05);border:2px solid var(--glow);border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:22px;float:right;margin-left:9px;}
.icf{margin-bottom:6px;}
.icf label{font-family:"Orbitron",sans-serif;font-size:6px;letter-spacing:1.5px;color:var(--muted);display:block;margin-bottom:1px;}
.icf .v{font-family:"Orbitron",sans-serif;font-size:10px;color:var(--text);font-weight:700;min-height:15px;}
.icf .v.mono{color:var(--accent);letter-spacing:2px;}
.icstripe{height:22px;background:linear-gradient(90deg,var(--glow2),var(--glow));margin-top:10px;border-radius:3px;opacity:.15;}
.gname{font-family:"Orbitron",sans-serif;font-size:28px;font-weight:900;color:var(--glow);text-shadow:0 0 20px rgba(0,229,255,.4);margin-bottom:5px;letter-spacing:3px;text-align:center;}
.qmodes{display:flex;gap:10px;margin-bottom:14px;}
.qmb{flex:1;background:var(--card);border:2px solid var(--border);border-radius:11px;padding:14px 8px;text-align:center;cursor:pointer;transition:all .3s;}
.qmb:hover{border-color:var(--glow);background:rgba(0,229,255,.08);}
.qmb .qi{font-size:26px;display:block;margin-bottom:5px;}
.qmb h3{font-family:"Orbitron",sans-serif;font-size:9px;letter-spacing:1px;color:var(--glow);}
.qmb p{font-size:9px;color:var(--muted);margin-top:2px;}
.lgrid{display:grid;grid-template-columns:repeat(5,1fr);gap:5px;}
.lbtn{background:var(--card);border:1px solid var(--border);border-radius:7px;padding:9px 3px;text-align:center;cursor:pointer;font-family:"Orbitron",sans-serif;font-size:8px;color:var(--muted);transition:all .3s;}
.lbtn:hover{border-color:var(--glow);color:var(--glow);}
.lbtn.done{border-color:var(--accent);color:var(--accent);background:rgba(57,255,20,.06);}
.lstep{background:var(--card);border:1px solid var(--border);border-radius:9px;padding:14px;margin-bottom:8px;}
.lstep .zorb{font-family:"Orbitron",sans-serif;font-size:20px;color:var(--glow);font-weight:900;margin-bottom:3px;}
.lstep .eng{font-size:12px;color:var(--text);}
.lstep .note{font-size:10px;color:var(--muted);font-style:italic;margin-top:3px;}
.qqitem{background:var(--card);border:1px solid var(--border);border-radius:11px;padding:16px;margin-bottom:10px;}
.qqtext{font-family:"Orbitron",sans-serif;font-size:14px;color:var(--glow);text-align:center;margin-bottom:14px;letter-spacing:1px;}
.qopts{display:flex;flex-direction:column;gap:7px;}
.qopt{background:rgba(0,229,255,.04);border:1px solid var(--border);border-radius:7px;padding:10px;font-family:"Exo 2",sans-serif;font-size:12px;color:var(--text);cursor:pointer;transition:all .3s;text-align:left;width:100%;}
.qopt:hover{border-color:var(--glow);}
.qopt.ok{border-color:var(--accent);background:rgba(57,255,20,.1);color:var(--accent);}
.qopt.no{border-color:var(--red);background:rgba(255,107,107,.1);color:var(--red);}
.qprog{background:rgba(0,229,255,.1);border-radius:20px;height:5px;margin-bottom:10px;overflow:hidden;}
.qbar{height:100%;background:linear-gradient(90deg,var(--glow),var(--glow2));border-radius:20px;transition:width .4s;}
.qscore{text-align:center;padding:22px;background:var(--card);border:1px solid var(--glow);border-radius:11px;}
.qscore .big{font-family:"Orbitron",sans-serif;font-size:36px;font-weight:900;color:var(--glow);margin-bottom:5px;}
.qsgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;}
.qsb{background:var(--card);border:1px solid var(--border);border-radius:6px;padding:8px 3px;text-align:center;cursor:pointer;font-family:"Orbitron",sans-serif;font-size:8px;color:var(--muted);transition:all .3s;}
.qsb:hover,.qsb.done{border-color:var(--glow2);color:var(--glow2);}
.npcard{background:var(--card);border:1px solid var(--border);border-radius:11px;overflow:hidden;margin-bottom:9px;}
.nphdr{display:flex;align-items:center;gap:11px;padding:12px;cursor:pointer;}
.nphdr .pi{font-size:24px;}
.nphdr h3{font-family:"Orbitron",sans-serif;font-size:11px;color:var(--glow2);margin-bottom:2px;}
.nphdr p{font-size:9px;color:var(--muted);}
.napf{display:none;padding:0 12px 12px;}
.napf.open{display:block;}
.ncode{background:rgba(255,215,0,.06);border:1px solid var(--gold);border-radius:9px;padding:14px;text-align:center;margin:10px 0;}
.ncode .cv{font-family:"Orbitron",sans-serif;font-size:16px;color:var(--gold);letter-spacing:3px;font-weight:900;margin-bottom:5px;word-break:break-all;}
.ncode p{font-size:9px;color:var(--muted);}
.viw{background:rgba(255,215,0,.04);border:1px solid var(--gold);border-radius:7px;padding:10px;margin:8px 0;}
.viw label{font-family:"Orbitron",sans-serif;font-size:7px;letter-spacing:2px;color:var(--gold);display:block;margin-bottom:5px;}
.viw input{width:100%;background:transparent;border:none;font-family:"Orbitron",sans-serif;font-size:13px;color:var(--gold);letter-spacing:2px;outline:none;}
.dtabs{display:flex;gap:5px;margin-bottom:12px;overflow-x:auto;scrollbar-width:none;}
.dtabs::-webkit-scrollbar{display:none;}
.dtab{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:5px 11px;font-family:"Orbitron",sans-serif;font-size:8px;color:var(--muted);cursor:pointer;white-space:nowrap;transition:all .3s;flex-shrink:0;}
.dtab.active,.dtab:hover{border-color:var(--glow2);color:var(--glow2);}
.dpanel{display:none;}
.dpanel.active{display:block;}
/* DOCUMENT CARD WITH PHOTO */
.doc-card{border-radius:14px;overflow:hidden;margin-bottom:14px;box-shadow:0 4px 24px rgba(0,0,0,.4);}
.doc-card-pp{background:linear-gradient(135deg,#0a2040,#0d1f3c);border:2px solid var(--glow2);}
.doc-card-id{background:linear-gradient(135deg,#0d1f3c,#050a1a);border:2px solid var(--glow);}
.doc-card-nat{background:linear-gradient(135deg,#1a1a0a,#0d1f3c);border:2px solid var(--gold);}
.doc-card-img{width:100%;height:160px;display:flex;align-items:center;justify-content:center;font-size:70px;position:relative;overflow:hidden;}
.doc-card-img::before{content:"";position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(ellipse at center,rgba(0,229,255,.08),transparent);}
.doc-card-pp .doc-card-img{background:linear-gradient(135deg,#050e20,#0a2040);}
.doc-card-id .doc-card-img{background:linear-gradient(135deg,#020a10,#0d1f3c);}
.doc-card-nat .doc-card-img{background:linear-gradient(135deg,#100a00,#1a1500);}
.doc-watermark{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-20deg);font-family:"Orbitron",sans-serif;font-size:28px;font-weight:900;opacity:.06;white-space:nowrap;color:white;}
.doc-card-body{padding:14px;}
.doc-card-title{font-family:"Orbitron",sans-serif;font-size:10px;letter-spacing:2px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center;}
.doc-field{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:10px;}
.doc-field .dk{color:var(--muted);}
.doc-field .dv{color:var(--text);font-weight:600;font-family:"Orbitron",sans-serif;font-size:9px;text-align:right;}
.doc-badge{padding:2px 8px;border-radius:8px;font-size:7px;font-family:"Orbitron",sans-serif;}
.doc-badge.cur{background:rgba(57,255,20,.1);color:var(--accent);border:1px solid rgba(57,255,20,.3);}
.doc-badge.old{background:rgba(90,127,168,.1);color:var(--muted);border:1px solid var(--border);}
.doc-badge.apv{background:rgba(255,215,0,.1);color:var(--gold);border:1px solid rgba(255,215,0,.3);}
