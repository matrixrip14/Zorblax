function refreshDocs(){
  const reg=getReg();
  const ppRec=[],idRec=[],natRec=[];
  for(const[k,v] of Object.entries(reg)){
    if(k.startsWith('pp_'))continue;
    if(k.startsWith('nat_')){natRec.push(v);continue;}
    if(v&&v.passportHistory)v.passportHistory.forEach((h,i)=>ppRec.push({...h,name:v.name,zorName:v.zorName,isLatest:i===v.passportHistory.length-1}));
    if(v&&v.idHistory)v.idHistory.forEach((h,i)=>idRec.push({...h,name:v.name,zorName:v.zorName,isLatest:i===v.idHistory.length-1}));
  }
  const ppEl=document.getElementById('doc-passports-list');
  if(ppEl)ppEl.innerHTML=ppRec.length?ppRec.map(p=>ppDocHTML(p,p.isLatest)).join(''):'<p style="text-align:center;padding:24px;color:var(--muted);font-size:11px">No passports yet.</p>';
  const idEl=document.getElementById('doc-idcards-list');
  if(idEl)idEl.innerHTML=idRec.length?idRec.map(p=>idDocHTML(p,p.isLatest)).join(''):'<p style="text-align:center;padding:24px;color:var(--muted);font-size:11px">No ID cards yet.</p>';
  const natEl=document.getElementById('doc-natpapers-list');
  if(natEl)natEl.innerHTML=natRec.length?natRec.map(n=>natDocHTML(n)).join(''):'<p style="text-align:center;padding:24px;color:var(--muted);font-size:11px">No nationality papers yet.</p>';
}

