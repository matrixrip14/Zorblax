function showInstallBanner(){
  const banner = document.createElement('div');
  banner.id = 'installBanner';
  banner.style.cssText = 'position:fixed;bottom:0;left:0;right:0;background:linear-gradient(135deg,#0d1f3c,#050a1a);border-top:1px solid var(--glow);padding:14px 16px;z-index:9999;display:flex;align-items:center;gap:12px;';
