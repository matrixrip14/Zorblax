let e2z={},z2e={};
function buildLookup(){
  ALL_WORDS.forEach(w=>{
    e2z[w.e.toLowerCase()]=w.z;
    z2e[w.z.toLowerCase()]=w.e;
  });
  for(let i=0;i<=100;i++){e2z[String(i)]=NN[i];z2e[NN[i].toLowerCase()]=String(i);}
}

let tDir='e2z';
function setDir(d){
  tDir=d;
  document.querySelectorAll('.ttab').forEach(b=>b.classList.remove('active'));
  document.getElementById('btn-'+d).classList.add('active');
  const out=document.getElementById('transOutput');
  const lang = currentPlanet && currentPlanet.dict ? currentPlanet.lang.toUpperCase() : 'ZORBLAX';
  const shortLang = lang.length>8 ? lang.split(' ')[0] : lang;
  if(d==='e2z'){
