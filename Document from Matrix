function investigate(){
  const q=(document.getElementById('inv-input').value||'').trim();
  const res=document.getElementById('inv-result');
  const nf=document.getElementById('inv-notfound');
  res.style.display='none';nf.style.display='none';
  if(!q){showNotice('⚠ Enter a number!');return;}
  const reg=getReg();let rec=null;
  if(q.length===8)rec=reg[q]||null;
  else if(q.length===11){const id=reg['pp_'+q];if(id)rec=reg[id]||null;}
  if(!rec){nf.style.display='block';return;}
  const IR=(k,v)=>`<div class="ir"><span class="ik">${k}</span><span class="iv">${v}</span></div>`;
  document.getElementById('inv-profile').innerHTML=IR('Name',rec.name||'—')+IR('Zorblax Name',`<span style="color:var(--glow2)">${rec.zorName||'—'}</span>`)+IR('Rank',rec.rank!==undefined?RL(rec.rank):'—')+IR('Planet',rec.planet||'—')+IR('ID #',`<span style="color:var(--accent)">${rec.idNum||'—'}</span>`)+IR('Passport #',`<span style="color:var(--glow)">${rec.passportNum||'—'}</span>`);
  const pph=rec.passportHistory||[];
  document.getElementById('inv-passport-rec').innerHTML=pph.length?pph.map((h,i)=>`<div style="background:rgba(0,229,255,.03);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:6px">${IR('Passport #'+(i+1),h.num)+IR('Issued',h.date)+IR('Rank',h.rank)+IR('Planet',h.planet)}</div>`).join(''):'<div style="color:var(--muted);font-size:11px;padding:6px">None.</div>';
  const idh=rec.idHistory||[];
  document.getElementById('inv-id-rec').innerHTML=idh.length?idh.map((h,i)=>`<div style="background:rgba(57,255,20,.03);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:6px">${IR('ID #'+(i+1),h.idNum)+IR('Issued',h.date)+IR('Rank',h.rank)+IR('Planet Zorblax',h.planetZor||'—')}</div>`).join(''):'<div style="color:var(--muted);font-size:11px;padding:6px">None.</div>';
  const nth=rec.natHistory||[];
  document.getElementById('inv-nat-rec').innerHTML=nth.length?nth.map(h=>`<div style="background:rgba(255,215,0,.03);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:6px">${IR('Planet',h.planet)+IR('Date',h.date)+IR('Passport #',h.passportNum||'—')}</div>`).join(''):'<div style="color:var(--muted);font-size:11px;padding:6px">None.</div>';
  const evts=[];
  pph.forEach((h,i)=>evts.push({date:h.date,ev:'Passport #'+(i+1)+' issued ('+h.num+')'}));
  idh.forEach((h,i)=>evts.push({date:h.date,ev:'ID #'+(i+1)+' issued ('+h.idNum+')'}));
  nth.forEach(h=>evts.push({date:h.date,ev:'Nationality approved: '+h.planet}));
  document.getElementById('inv-log').innerHTML=evts.length?evts.map(e=>`<div class="ir"><span class="ik">${e.date}</span><span class="iv" style="color:var(--text);font-size:10px">${e.ev}</span></div>`).join(''):'<div style="color:var(--muted);font-size:11px;padding:6px">No activity.</div>';
  res.style.display='block';
}

