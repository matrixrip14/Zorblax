const LESSON_CATS=['Greetings','Sentences','Family','Nature','Emotions','Food','Space','Animals','Actions','Body','Time','Colors','Places','Slang'];
const LESSONS=Array.from({length:100},(_,i)=>{
  const words=[];
  for(let j=0;j<5;j++)words.push(ALL_WORDS[(i*5+j)%ALL_WORDS.length]);
  return{num:i+1,title:'Lesson '+(i+1)+': '+LESSON_CATS[i%LESSON_CATS.length]+' Part '+(Math.floor(i/LESSON_CATS.length)+1),words};
});
let _sr=42;
function _rnd(n){_sr=(_sr*1664525+1013904223)&0x7fffffff;return Math.abs(_sr)%n;}
const QUIZ_QS=Array.from({length:500},(_,i)=>{
  _sr=i*777+1;
  const correct=ALL_WORDS[i%ALL_WORDS.length];
  const opts=[correct];const used=new Set([correct.z]);let t=0;
  while(opts.length<4&&t<200){t++;const r=ALL_WORDS[_rnd(ALL_WORDS.length)];if(!used.has(r.z)){used.add(r.z);opts.push(r);}}
  opts.sort(()=>_rnd(3)-1);
  const type=i%2===0?'z2e':'e2z';
  return{q:type==='z2e'?correct.z:correct.e,ans:type==='z2e'?correct.e:correct.z,opts:opts.map(o=>type==='z2e'?o.e:o.z)};
});

