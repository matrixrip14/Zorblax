function getPlanetLangCode(){
  if(!currentPlanet || !currentPlanet.dict) return 'zorblax';
  return currentPlanet.langCode || 'zorblax';
}

function textToSpeech(text){
  // Get phoneme map for current planet
  const langCode = getPlanetLangCode();
  const map = PHONEME_MAPS[langCode] || PHONEME_MAPS.zorblax;

  let words = text.toLowerCase().split(/\s+/);
  let result = [];
  let i = 0;
  while(i < words.length){
    let matched = false;
    if(i+1 < words.length){
      const pair = words[i]+' '+words[i+1];
      if(map[pair]){result.push(map[pair]);i+=2;matched=true;}
    }
    if(!matched){
      const w = words[i].replace(/[^a-z]/g,'');
      result.push(map[w] || pronounceUnknown(w));
      i++;
    }
  }
  return result.join('. ');
}

function pronounceUnknown(word){
  // Break unknown word into pronounceable chunks
  if(!word) return '';
  // Add dots between consonant clusters to slow pronunciation
  return word.replace(/([^aeiou]{2,})/g, (m) => m.split('').join('-'))
             .replace(/([aeiou]+)/g, '$1');
}

function makePhonetic(text){
  const langCode = getPlanetLangCode();
  const map = PHONEME_MAPS[langCode] || PHONEME_MAPS.zorblax;
  const words = text.toLowerCase().split(/\s+/);
  const result = words.map(w => {
    const clean = w.replace(/[^a-z]/g,'');
    return '[' + (map[clean] || clean) + ']';
  });
  return '🔤 ' + result.join(' · ');
}

let isSpeaking = false;

function pronounceOutput(){
  const text = document.getElementById('transOutput').textContent;
  if(!text || text === 'Translation will appear here...' || text === 'Please enter text first.') return;

  if(!window.speechSynthesis){
    document.getElementById('pronStatus').textContent = '⚠ Speech not supported in this browser';
    return;
  }

  if(isSpeaking){
    window.speechSynthesis.cancel();
    isSpeaking = false;
    document.getElementById('pronounceBtn').textContent = '🔊 PRONOUNCE';
    document.getElementById('pronStatus').textContent = '';
    return;
  }

  const langCode = getPlanetLangCode();
  const speechText = textToSpeech(text);
  const utter = new SpeechSynthesisUtterance(speechText);

  // Choose voice settings per planet language
  const voiceSettings = {
    zorblax:   {pitch:0.55, rate:0.7,  lang:'en-US'},
    zibblonic: {pitch:1.4,  rate:0.8,  lang:'en-GB'},
    lunarian:  {pitch:1.6,  rate:1.1,  lang:'en-US'},
    zarbish:   {pitch:0.5,  rate:0.65, lang:'en-US'},
    kryptonian:{pitch:0.4,  rate:0.6,  lang:'en-GB'},
    vexoric:   {pitch:0.7,  rate:0.75, lang:'en-AU'},
    blorbian:  {pitch:0.3,  rate:0.55, lang:'en-US'},
    grexian:   {pitch:0.6,  rate:0.5,  lang:'en-GB'},
    earth:     {pitch:1.0,  rate:0.85, lang:'en-US'},
  };

  const settings = voiceSettings[langCode] || voiceSettings.zorblax;
  utter.pitch = settings.pitch;
  utter.rate = settings.rate;
  utter.volume = 1.0;
  utter.lang = settings.lang;

  // Try to pick a matching voice
  function doSpeak(){
    const voices = window.speechSynthesis.getVoices();
    const match = voices.find(v => v.lang.startsWith(settings.lang.split('-')[0])) || voices[0];
    if(match) utter.voice = match;

    isSpeaking = true;
    const planetName = currentPlanet ? currentPlanet.lang : 'Zorblax';
    document.getElementById('pronounceBtn').textContent = '⏹ STOP';
    document.getElementById('pronStatus').textContent = '👽 Speaking ' + planetName + '...';

    utter.onend = () => {
      isSpeaking = false;
      document.getElementById('pronounceBtn').textContent = '🔊 PRONOUNCE';
      document.getElementById('pronStatus').textContent = '✅ Done';
      setTimeout(()=>{ document.getElementById('pronStatus').textContent=''; }, 2000);
    };
    utter.onerror = (e) => {
      isSpeaking = false;
      document.getElementById('pronounceBtn').textContent = '🔊 PRONOUNCE';
      document.getElementById('pronStatus').textContent = '⚠ ' + e.error;
    };
    window.speechSynthesis.speak(utter);
  }

  const voices = window.speechSynthesis.getVoices();
  if(voices.length === 0){
    window.speechSynthesis.onvoiceschanged = doSpeak;
  } else {
    doSpeak();
  }
}

// ══ BACKUP & RESTORE ══════════════════════════
function backupData(){
  const data = {};
  for(let i=0;i<localStorage.length;i++){
    const key = localStorage.key(i);
    if(key && key.startsWith('zbl_')){
      data[key] = localStorage.getItem(key);
    }
  }
  if(Object.keys(data).length === 0){
    document.getElementById('backupStatus').textContent = '⚠ No data to backup yet.';
    return;
  }
  const blob = new Blob([JSON.stringify(data, null, 2)], {type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'zorblax-backup-' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
  URL.revokeObjectURL(url);
  document.getElementById('backupStatus').textContent = '✅ Backup downloaded!';
  setTimeout(()=>document.getElementById('backupStatus').textContent='', 3000);
}

function restoreData(input){
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    try{
      const data = JSON.parse(e.target.result);
      let count = 0;
      for(const [key, val] of Object.entries(data)){
        if(key.startsWith('zbl_')){
          localStorage.setItem(key, val);
          count++;
        }
      }
      document.getElementById('backupStatus').textContent = '✅ Restored ' + count + ' items! Reloading...';
      setTimeout(()=>location.reload(), 1500);
    } catch(err){
      document.getElementById('backupStatus').textContent = '⚠ Invalid backup file.';
    }
  };
  reader.readAsText(file);
  input.value = '';
}

