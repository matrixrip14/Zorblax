function SP(page, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
  const el = document.getElementById(page);
  if(el) el.classList.add('active');
  if (btn) btn.classList.add('active');
  if (page === 'identity') loadSavedIdentity();
  if (page === 'documents') refreshDocs();
  if (page === 'leaderboard') showLB('gdp', document.querySelector('.lbtb'));
  if (page === 'quiz') updateQP();
  if (page === 'travel') renderTravelPlanets();
}

// ── STORAGE ──────────────────────────────────
function SG(k){try{return JSON.parse(localStorage.getItem('zbl_'+k))}catch(e){return null}}
function SS(k,v){try{localStorage.setItem('zbl_'+k,JSON.stringify(v))}catch(e){}}
function getReg(){return SG('registry')||{}}
function saveReg(r){SS('registry',r)}

// ── NOTICE ───────────────────────────────────
function showNotice(msg){
  let n=document.querySelector('.notice');
  if(!n){n=document.createElement('div');n.className='notice';document.body.appendChild(n);}
  n.textContent=msg;n.style.opacity='1';
  clearTimeout(n._t);n._t=setTimeout(()=>{n.style.opacity='0';},2500);
}

